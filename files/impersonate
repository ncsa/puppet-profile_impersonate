#!/usr/bin/perl

$ENV{'PATH'} = '/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin';
use strict;
use warnings;
#use LWP::UserAgent;
#use JSON;

# --- Optional Variables ---
my $slack_webhook_url = "https://hooks.slack.com/services/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";

# --- Input Parameters ---
my $user   = shift or die "Usage: $0 username [reason]\n";  # Required: target username
my $reason = shift // '';                                   # Optional: reason for impersonation

# --- Get user info from system ---
my $id = `/usr/bin/getent passwd $user` or die "No such user: $user\n";
my ($homedir, $sh) = $id =~ m/.*:.*:.*:.*:(\S+):(\S+)$/;
die "Home directory for $user does not exist\n" unless -d $homedir;

# --- Determine impersonator and timestamp ---
my $IMPERSONATOR = $ENV{LOGNAME} || $ENV{USER} || getpwuid($<);
my $DATE = qx(date +%Y%m%d%H%M%S);
chomp $DATE;

# --- Format reason for logging ---
my $reason_text = $reason ? " Reason: $reason" : "";
my $start_msg = "User $IMPERSONATOR is impersonating user $user.$reason_text";
my $end_msg   = "User $IMPERSONATOR has ended impersonating user $user.$reason_text";

system("logger -t impersonate '$start_msg'");
send_slack_message($slack_webhook_url, $start_msg);

# --- Prepare history file path ---
my $HISTORY_FILE = "$homedir/.$user.$IMPERSONATOR";

# --- Prepare end-of-session log command ---
my $cmd_end_log = "logger -t impersonate User\\ $IMPERSONATOR\\ has\\ ended\\ impersonating\\ user\\ $user.$reason_text";
#my $cmd_end_log = "printf '%s\\n' '$end_msg' | logger -t impersonate; ";
#if ($slack_webhook_url) {
#    $cmd_end_log .= "curl -s -X POST -H 'Content-type: application/json' --data '{\"text\":\"$end_msg\"}' \"$slack_webhook_url\" > /dev/null 2>&1";
#}

# --- Dispatch to appropriate shell handler ---
my $cmd;
if ($sh =~ /bash/) {
    $cmd = build_bash_command($user, $HISTORY_FILE, $cmd_end_log);
}
elsif ($sh =~ /csh/) {
    $cmd = build_csh_command($user, $HISTORY_FILE, $cmd_end_log);
}
elsif ($sh =~ /zsh/) {
    $cmd = build_zsh_command($user, $HISTORY_FILE, $cmd_end_log);
}
else {
    die "User's shell not supported: $user with shell $sh\nContact help\@ncsa.illinois.edu\n";
}

# --- Execute impersonation ---
exec $cmd;

# --- Subroutines for shell-specific logic ---

sub build_bash_command {
    my ($user, $history_file, $end_log) = @_;
    return "sudo -u $user /usr/bin/bash -l -c '"
         . "[ -f ~/.bash_commands.log ] && mv ~/.bash_commands.log ~/.bash_commands.log.sav.$$; "
         . "[ -f $history_file ] && mv $history_file ~/.bash_commands.log; "
         . "cd ~; /usr/bin/bash; "
         . "[ -f ~/.bash_commands.log ] && mv ~/.bash_commands.log $history_file; "
         . "[ -f ~/.bash_commands.log.sav.$$ ] && mv ~/.bash_commands.log.sav.$$ ~/.bash_commands.log; "
         . "$end_log'";
}

sub build_csh_command {
    my ($user, $history_file, $end_log) = @_;
    return "sudo -u $user /usr/bin/tcsh -c '"
         . "[ -f ~/.history ] && mv ~/.history ~/.history.sav; "
         . "[ -f $history_file ] && mv $history_file ~/.history; "
         . "/usr/bin/tcsh -l; "
         . "[ -f ~/.history ] && mv ~/.history $history_file; "
         . "[ -f ~/.history.sav ] && mv ~/.history.sav ~/.history; "
         . "$end_log'";
}

sub build_zsh_command {
    my ($user, $history_file, $end_log) = @_;
    return "sudo -u $user /usr/bin/zsh -l -c '"
         . "if [ -z \$HISTFILE ]; then HISTFILE=~/.zsh_history; fi; "
         . "[ -f \$HISTFILE ] && mv \$HISTFILE \$HISTFILE.sav.$$; "
         . "[ -f $history_file ] && mv $history_file \$HISTFILE; "
         . "cd ~; /usr/bin/zsh -l; "
         . "[ -f \$HISTFILE ] && mv \$HISTFILE $history_file; "
         . "[ -f \$HISTFILE.sav.$$ ] && mv \$HISTFILE.sav.$$ \$HISTFILE; "
         . "$end_log'";
}

sub send_slack_message {
    my ($webhook_url, $text) = @_;
    return unless $webhook_url;

    # Escape double quotes in the message to avoid breaking JSON
    $text =~ s/"/\\"/g;

    my $hostname = qx(hostname -s);
    chomp $hostname;

    my $curl_cmd = "curl -s -X POST -H 'Content-type: application/json' "
                 . "--data '{\"username\": \"User Impersonation\", \"text\":\"$text - on $hostname\", \"icon_emoji\": \":male-detective:\"}' \"$webhook_url\" > /dev/null 2>&1";

    system($curl_cmd);
}
